# Supabase Dashboard > Project Settings > Database > Connection string (JDBC)
DATABASE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-supabase-database-password

# JWT signing key (32+ characters recommended)
JWT_SECRET=your-secret-key-here-make-it-long-and-secure-in-production
